{
  "manifest_version": 3,
  "name": "小红书评论洞察助手",
  "version": "1.1.0",
  "description": "在小红书笔记详情页，提取笔记标题、筛选精华评论、生成评论总结",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://api.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.xiaohongshu.com/*"],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "小红书评论洞察助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
